{
  "expo": {
    "name": "rollfinder",
    "slug": "rollfinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/rollfinder.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/rollfinder.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lydotwav.rollfinder"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/rollfinder.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/rollfinder.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "bc281b45-341d-4d9c-859f-224fe819016b"
      }
    }
  }
}
